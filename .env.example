# pHive Vercel Environment Variables
# Copy this to .env.local and fill in your values

# Vercel KV (Redis)
# Get these from your Vercel KV dashboard
KV_URL=https://YOUR_KV_URL:YOUR_PORT
KV_REST_API_URL=https://YOUR_KV_REST_API_URL
KV_REST_API_TOKEN=YOUR_KV_REST_API_TOKEN

# pHive Bootnode Authentication
# Use a strong, random token for security
PHIVE_SECRET_KEY=your_super_secret_token_here_change_in_production

# Domain Fronting (Reverse Proxy)
# Replace with your actual hidden server domain or IP
HIDDEN_SERVER_URL=https://your-actual-server.com

# Optional: Analytics and Monitoring
VERCEL_URL=https://phive-five.vercel.app
