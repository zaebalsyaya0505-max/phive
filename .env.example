# pHive Vercel Environment Variables
# Copy this to .env.local and fill in your values

# CRITICAL: Change these before deploying to production!
# DO NOT use these example values in production

# Vercel KV (Redis)
# Get these from your Vercel KV dashboard
KV_URL=https://your-kv-url:your-port
KV_REST_API_URL=https://your-kv-rest-api-url
KV_REST_API_TOKEN=your_kv_rest_api_token_change_in_prod

# pHive Bootnode Authentication
# Use a strong, random token (min 32 chars, alphanumeric + special chars)
# Generate with: openssl rand -base64 32
PHIVE_SECRET_KEY=your_strong_random_secret_key_minimum_32_characters

# CORS Configuration
# Set to your production domain for security
ALLOWED_ORIGIN=https://phive-five.vercel.app

# Domain Fronting (Reverse Proxy)
# Replace with your actual hidden server domain or IP
HIDDEN_SERVER_URL=https://your-actual-server.com

# Supabase Configuration (Safe - Anon key is intentionally public)
# Get these from your Supabase project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional: Analytics and Monitoring
VERCEL_URL=https://phive-five.vercel.app
